# Hermes KanbanWebUI local configuration example
# Copy to ~/.hermes/kanban-webui.env or run ./scripts/install.sh.
# Values are shell syntax and are sourced by scripts/hermes-kanban.

# Real OS home. Override only if Hermes runs with a profile-specific HOME.
HERMES_REAL_HOME="${HOME}"

# Checkout paths.
HERMES_KANBAN_WEBUI_APP_DIR="${HERMES_REAL_HOME}/.local/share/hermes-kanban"
HERMES_AGENT_ROOT="${HERMES_REAL_HOME}/.hermes/hermes-agent"

# Local-only HTTP defaults.
HERMES_KANBAN_WEBUI_HOST=127.0.0.1
HERMES_KANBAN_WEBUI_PORT=8790

# Runtime state and logs.
HERMES_KANBAN_WEBUI_STATE="${HERMES_REAL_HOME}/.hermes/kanban-webui"
HERMES_KANBAN_WEBUI_LOG="${HERMES_REAL_HOME}/.hermes/logs/kanban-webui.log"

# Optional: require X-Kanban-Token or Authorization: Bearer for /api/* and /service/status.
# Leave empty for localhost-only personal use.
HERMES_KANBAN_WEBUI_TOKEN=

# Optional: comma-separated DNS hostnames allowed by Host-header validation.
# Example: my-host.example.ts.net
HERMES_KANBAN_WEBUI_ALLOWED_HOSTS=

# AI Workflow Designer.
# Set to 0/false/off to disable Hermes CLI planner calls.
HERMES_KANBAN_WORKFLOW_AI_ENABLED=true

# Optional preferred planner profile. If empty, KanbanWebUI falls back to:
# request value -> dev_plan if present -> default if present -> first on-disk profile.
HERMES_KANBAN_WORKFLOW_PLANNER_PROFILE=

# Workflow draft limits.
HERMES_KANBAN_WORKFLOW_DEFAULT_MAX_STEPS=8
HERMES_KANBAN_WORKFLOW_MAX_STEPS=20
HERMES_KANBAN_WORKFLOW_ATTACHMENT_MAX_FILES=5
HERMES_KANBAN_WORKFLOW_ATTACHMENT_MAX_BYTES=200000
HERMES_KANBAN_WORKFLOW_PLANNER_TIMEOUT_SECONDS=180
